{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["./src/**/*.ts", "./types/**/*.d.ts"],
  "exclude": ["node_modules", "dist"],
  "typeRoots": ["./node_modules/@types", "./types"]
}
